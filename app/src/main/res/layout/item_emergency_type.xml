<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="4dp">

    <FrameLayout
        android:id="@+id/flEmergencyIconContainer"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_report_emergency_icon_unselected"
        android:foreground="?attr/selectableItemBackgroundBorderless">

        <ImageView
            android:id="@+id/ivEmergencyIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:contentDescription="@string/report_emergency_icon"
            android:tint="@color/report_icon_inactive" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvEmergencyName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="@color/report_label_inactive"
        android:textSize="15sp"
        android:textStyle="bold" />
</LinearLayout>
