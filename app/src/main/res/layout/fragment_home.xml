<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <com.trackasia.android.maps.MapView
        android:id="@+id/home_map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:trackasia_renderTextureMode="true"
        app:trackasia_renderTextureTranslucentSurface="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp">


    </LinearLayout>

    <FrameLayout
        android:id="@+id/layout_home_sos"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="168dp">

        <View
            android:id="@+id/sos_pulse_2"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:alpha="0.0"
            android:background="@drawable/bg_home_sos_pulse" />

        <View
            android:id="@+id/sos_pulse_1"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:alpha="0.0"
            android:background="@drawable/bg_home_sos_pulse" />

        <View
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_home_sos_ring" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_home_sos"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/color_primary"
            app:cardCornerRadius="26dp"
            app:cardElevation="0dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/home_sos_label"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

</RelativeLayout>
